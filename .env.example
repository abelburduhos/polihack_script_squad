# Copy to .env and fill in values

# ---- Auth (change before exposing to network) ----
ADMIN_USER=admin
ADMIN_PASS=admin
CLIENT_USER=viewer
CLIENT_PASS=viewer

# ---- OpenWeatherMap (free tier) ----
# Get at: https://openweathermap.org/api
# Without this, all alarms default to verdict "real".
WEATHER_API_KEY=your_key_here

# ---- Optional overrides ----
# PORT=3000
# PGHOST=localhost
# PGPORT=5432
# PGUSER=cdm
# PGPASSWORD=cdm
# PGDATABASE=cdm
